function PCBuild-CheckForModuleOrPackage {
    param (
        [Parameter(Mandatory=$true)]
        [string]$PackageOrModuleName,
        [Parameter(Mandatory=$true)]
        [ValidateSet("Module","PackageProvider")]
        [string]$PackageOrModuleType
    )

    try {
        if (iex "Get-$($PackageOrModuleType) $($PackageOrModuleName) -ListAvailable -ea SilentlyContinue") {
            Write-Host "$($PackageOrModuleType) $($PackageOrModuleName) already installed and imported." -ForegroundColor Green
        } else {
            iex "Install-$($PackageOrModuleType) -Name $($PackageOrModuleName) -Force"
            iex "Import-$($PackageOrModuleType) -Name $($PackageOrModuleName)"
            Write-Host "$($PackageOrModuleType) $($PackageOrModuleName) installed and imported successfully" -ForegroundColor Yellow
        }
    }
    catch {
        Write-Host "An error has occurred: $($_)"
    }
}

function PCBuild-RenameComputer {
    $ErrorActionPreference = 'stop'
    $ProgressPreference = 'silentlycontinue'
    
    $RegPath = "HKLM:\SOFTWARE\WOW6432Node\Splashtop Inc.\Splashtop Remote Server"
    $RegName = "CloudComputerName"
    try { 
        while (1) {
            $h1 = read-host -prompt "Type new hostname below and press ENTER to continue"; 
            $h2= read-host -prompt "CONFIRM - RE-ENTER new hostname below and press ENTER to continue";
            if ($h1 -eq $h2) {
                Write-Host "New Hostname is a match! Computer will be renamed to $($h1). Press any key to continue." -ForegroundColor Green
                Pause
    
                rename-computer -newname $h1
                    Write-Host "Renamed computer to $($h1)" -ForegroundColor Green
                Set-ItemProperty -Path $RegPath -Name $RegName -Value $ENV:COMPUTERNAME
                    Write-Host "Set $($RegPath) $($RegName) to $($h1)" -ForegroundColor Green
                    Write-Host ""
                    Write-Host ""
                    Write-Host "Press any key to restart computer and apply changes." -ForegroundColor Yellow
                    pause
                    restart-computer -force
                    break;
            } else {
                Write-Host "Hostnames do not match. Press any key to re-enter new hostname." -ForegroundColor Yellow
            }
        }
    }
    catch {
        Write-Host "An error has occurred: $($_)" -ForegroundColor Red
    }
}

function PCBuild-SetPowerManagement {
    param (
        $ConfigFile = "DEFAULT"
    )

    <#
    Baseline Power Management
                                        Plugged in:             Battery:
        Monitor Timeout                 30 minutes              3 minutes
        Disk Timeout                    30 minutes              5 minutes
        Standby Timeout                 0 minutes (never)       10 minutes
        Hibernate Timeout               0 minutes (never)       0 minutes (never)
        Hibernation:        OFF
        Wake Timers:                    1 (Enabled)             1 (Enabled)
        Closing the Lid (Laptops):      0 (Do Nothing)      1 (Sleep)
    #>

# Define the settings
try {
    if ($ConfigFile -eq "DEFAULT") {
        $Args = @(
            ("/change monitor-timeout-ac 30"),                                                                                  # Plugged in:       Monitor timeout 30 minutes
            ("/change monitor-timeout-dc 3"),                                                                                   # Battery:          Monitor timeout 30 minutes
            ("/change disk-timeout-ac 30"),                                                                                     # Plugged in:       Disk timeout 30 minutes
            ("/change disk-timeout-dc 5"),                                                                                      # Battery:          Disk timeout 5 minutes
            ("/change standby-timeout-ac 0"),                                                                                   # Plugged in:       Standby (Sleep) 0 minutes (Never)
            ("/change standby-timeout-dc 5"),                                                                                   # Battery:          Standby (Sleep) 5 minutes
            ("/change hibernate-timeout-ac 0"),                                                                                 # Plugged in:       Hibernate 0 minutes (Never)
            ("/change hibernate-timeout-dc 0"),                                                                                 # Battery:          Hibernate 0 minutes (Never)
            ("-h off"),                                                                                                         #                   Hibernation OFF
            ("/SETACVALUEINDEX SCHEME_CURRENT 238c9fa8-0aad-41ed-83f4-97be242c8f20 bd3b718a-0680-4d9d-8ab2-e1d2b4ac806d 1"),    # Plugged in:       Wake Timers 1 (Enabled)
            ("/SETDCVALUEINDEX SCHEME_CURRENT 238c9fa8-0aad-41ed-83f4-97be242c8f20 bd3b718a-0680-4d9d-8ab2-e1d2b4ac806d 1"),    # Wake Timers:      Wake Timers 1 (Enabled)
            ("/setACvalueIndex scheme_current sub_buttons lidAction 0"),                                                        # Plugged in:       Close Lid - 0 (Do Nothing)
            ("/setDCvalueIndex scheme_current sub_buttons lidAction 1"),                                                        # Battery:          Close Lid - 1 (Sleep)
            ("/setActive scheme_current")                                                                                       # Apply settings to current power scheme
        )
    } else {
        Throw "You must provide a configuration file to continue. This has not been scripted yet."
    }

    # Set power management settings:
    $Args | foreach {
          $p = Start-Process powercfg -WorkingDirectory "C:\Windows\System32" -windowstyle Hidden -ArgumentList $_ -PassThru -Wait
          If ($p.ExitCode -eq 0) {
            Write-Host "Successfully ran Powercfg" $_
          } else {
            Throw $p.ExitCode
          }
    }
} catch {
  Write-Host "An error occurred:" $_ -ForegroundColor Red
}
}


