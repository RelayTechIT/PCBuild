function PCBuild-DisableIPv6 {
    param (
        $DisableIPv6
    )
    try {
        If ($DisableIPv6) {
            Get-NetAdapterBinding | Where {$_.ComponentID -eq "ms_tcpip6"} | Where {$_.Enabled} | Disable-NetAdapterBinding
            Write-Host "Successfully disabled IPv6 on all network adapters"
      } else {
            Write-Host "The DisableIPv6 variable is not set to true. No action taken."
      }
    }
    catch {
      Write-Host "An error occurred: $($_)"
    }
}


function PCBuild-SetWindowsTime {
param (
        $TimeZone,
        $TimeServer
    )
    Try {
        If (!$TimeZone) {Throw "Missing required paremeter: TIMEZONE. Script cannot continue."}
        If (!$TimeServer) {Throw "Missing required paremeter: TIMESERVER. Script cannot continue."}

      if ((Get-ComputerInfo).CsPartOfDomain) {
        Throw "$($ENV:Computername) is part of domain $((Get-ComputerInfo).CsPartOfDomain). Time is set by domain controller."
      }

  # Check Timeserver and set if needed
    Get-Service "Windows Time" | Stop-Service
    Start-Process w32tm -ArgumentList "/unregister" -Wait -NoNewWindow
    Start-Process w32tm -ArgumentList "/register" -Wait -NoNewWindow
    Get-Service "Windows Time" | Start-Service

      if ((Get-Service "Windows Time" -ea silentlycontinue).Status -eq "Running") {
        $CurrentTimeServer = (w32tm /query /status | where {$_ -match "Source:"}).split(" ")[1]
      } else {
        Write-Host "Windows Time Service is not running"
      }

    if ($CurrentTimeZone -eq $TimeZone) {
      Write-Host "Time Server already set to $($TimeServer)"
    } else {
      $Test = Test-NetConnection -ComputerName $TimeServer -InformationLevel "Detailed"
        Write-Host "Timeserver is active"
        Start-Process w32tm -ArgumentList "/config /manualpeerlist:$TimeServer /syncfromflags:manual /update" -Wait -NoNewWindow
        Start-Process w32tm -ArgumentList "/config /update" -Wait -NoNewWindow
        Start-Process w32tm -ArgumentList "/resync /rediscover" -Wait -NoNewWindow
        Start-Process w32tm -ArgumentList "/query /status" -Wait -NoNewWindow
        Write-Host "Successfully set windows time server to $($TimeServer)" -ForegroundColor Green
    }   

  # Check Timezone and set if needed
  $CurrentTimeZone = Get-TimeZone | select -ExpandProperty StandardName
    if ($CurrentTimeZone -eq $TimeZone) {
      Write-Host "Time zone already set to $($TimeZone)"
    } else {
      Set-TimeZone $TimeZone
      Write-Host "Timezone set to $($TimeZone) successfully" -ForegroundColor Green
    }
} catch {
        Write-Host "An error occurred: $($_)"
    }
}

function PCBuild-RemoveAppxProvisionedPackages {
param (
    $Packages
)
foreach ($AppxProvPkg in $AppxProvPkgs) {
        $Pkg = get-appxprovisionedpackage -Online -ea SilentlyContinue | where {$_.DisplayName -like "*$($AppxProvPkg)*"}
        if ($Pkg) {
            Write-Host "Removing provisioned package $($Pkg.DisplayName)..." -ForegroundColor Yellow
            Remove-AppxProvisionedPackage -Online -PackageName $Pkg.PackageName -ea SilentlyContinue
        } else {
            Write-Host "Provisioned package $($AppxProvPkg) not found, skipping." -ForegroundColor Green
        }
    }
}

function PCBuild-RemoveAppxPackages {
param (
    $Packages
)
    foreach ($AppxPkg in $AppxPkgs) {
        $Pkg = Get-AppxPackage -AllUsers | where {$_.Name -like "*$($AppxPkg)*"}
        if ($Pkg) {
                Write-Host "Removing Appx package $($Pkg.Name)..." -ForegroundColor Yellow
                $Pkg | Remove-AppxPackage -allusers
            } else {
                Write-Host "Appx package $($AppxPkg) not found, skipping." -ForegroundColor Green
            }
    }
}

function Import-SyncroModule {
   param (
       $UUID # Defaults to the UUID of the local system or specify another Syncro Asset UUID
   )
   # Ensure TLS 1.2 or higher is enabled
   if ([Net.ServicePointManager]::SecurityProtocol -lt [Net.SecurityProtocolType]::Tls12) {
       [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
   }
   # Set up environment variables for Syncro
   if ($env:SyncroModule -match '^\s*$') {
       $SyncroRegKey = Get-ItemProperty -Path 'HKLM:\SOFTWARE\WOW6432Node\RepairTech\Syncro' -Name uuid, shop_subdomain
       $env:RepairTechSyncroApiUrl = "https://${SyncroRegKey.shop_subdomain}.syncromsp.com"
       $env:RepairTechUUID = if ($UUID -match '^\s*$') { $SyncroRegKey.uuid } else { $UUID }
       $env:SyncroModule = "$env:ProgramData\Syncro\bin\module.psm1"
   }
   # Import the module if compatible
   if ((Test-Path -Path $env:SyncroModule) -and ($PSVersionTable.PSVersion -ge [system.version]'4.0')) {
       Import-Module -Name $env:SyncroModule -WarningAction SilentlyContinue
   } else {
       Write-Warning "PowerShell version is not compatible with SyncroModule."
   }
}
